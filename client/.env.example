# Copy to client/.env.local and fill in. .env.local is git-ignored.

# Backend host the browser connects to (WSS + REST via the Vite proxy).
VITE_BACKEND_HOST=openmmo.to.nexus

# Dev-server TLS cert paths (relative to client/).
VITE_HTTPS_KEY=./.certs/key.pem
VITE_HTTPS_CERT=./.certs/cert.pem
VITE_HTTPS_CA=./.certs/ca.pem

# Vite HMR over the tunnel.
VITE_HMR_HOST=openmmo.to.nexus
VITE_HMR_PROTOCOL=wss

# Google OAuth *Web* client ID (public value, same one the server gets via
# GOOGLE_CLIENT_ID). Required — the login screen shows an error without it.
# Create one at https://console.cloud.google.com/apis/credentials and add the
# dev origin (e.g. https://openmmo.to.nexus:10004) to Authorized JS origins.
VITE_GOOGLE_CLIENT_ID=
