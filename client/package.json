{
  "name": "onlinerpg-client",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build:wasm": "npm run generate:footprints && rm -rf src/lib/wasm && cd ../shared && wasm-pack build --target web --out-dir ../client/src/lib/wasm",
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vite build",
    "preview": "vite preview",
    "check": "npm run generate:csv && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run generate:csv && eslint . --ext .js,.ts,.svelte",
    "lint:fix": "eslint . --ext .js,.ts,.svelte --fix",
    "test": "npm run generate:csv && vitest run",
    "test:watch": "npm run generate:csv && vitest",
    "generate:csv": "node ../tools/convert.mjs",
    "generate:data": "npm run generate:csv && node ../tools/extract-animation-durations.mjs",
    "generate:footprints": "node ../tools/measure-furniture-footprints.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@sveltejs/vite-plugin-svelte": "^6.1.0",
    "@tsconfig/svelte": "^5.0.4",
    "@types/node": "^25.2.2",
    "eslint": "^9.33.0",
    "eslint-plugin-svelte": "^3.11.0",
    "globals": "^16.3.0",
    "jiti": "^2.5.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^4.1.1",
    "svelte": "^5.53.12",
    "svelte-check": "^4.3.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.39.0",
    "vite": "^7.1.0",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@threlte/core": "^8.4.1",
    "@threlte/extras": "^9.8.1",
    "@types/three": "^0.184.0",
    "three": "^0.184.0"
  }
}
