# Agent client configuration

# Server WebSocket URL
server = "ws://127.0.0.1:10006"

# Account credentials
account = ""
password = ""

# Set to true to create a new account instead of logging in
create_account = false

# MCP HTTP server port (default: 8808)
# mcp_port = 8808

# LLM backend to use: "none", "claude", "openrouter", "codex"
# - none: no LLM driver (MCP or direct mode)
# - claude: Claude CLI (stdio subprocess)
# - openrouter: OpenRouter API (HTTP, any model)
# - codex: Codex CLI (stdio subprocess)
llm = "none"

# LLM timing (seconds)
min_interval_secs = 5                       # Minimum seconds between prompts (active mode)
debounce_secs = 2                           # Extra wait to batch events after trigger
idle_interval_secs = 3600                   # Interval when no chat/combat activity (idle mode)
activity_window_secs = 30                   # How long after last activity to stay in active mode

# LLM Scheduler: controls concurrent LLM calls across all NPCs
max_concurrent = 2                          # Max simultaneous LLM calls (default: 2)

# Claude CLI settings (used when llm = "claude")
[claude]
model = "sonnet"                            # "sonnet", "opus", "haiku", or full model ID
system_prompt_file = "data/system_prompt.txt"  # Path to system prompt file

# OpenRouter API settings (used when llm = "openrouter")
# Uses OpenAI-compatible chat completions API to call any model available on OpenRouter.
[openrouter]
# api_key = "sk-or-..."                        # Or set OPENROUTER_API_KEY env var
model = "openrouter/hunter-alpha"              # Any model ID from openrouter.ai/models
system_prompt_file = "data/system_prompt.txt"
max_tokens = 1024                              # Max response tokens
temperature = 0.7

# Codex CLI settings (used when llm = "codex")
# Requires `codex` CLI installed (npm i -g @openai/codex) and OPENAI_API_KEY set.
[codex]
model = "o4-mini"                                # Any OpenAI model ID
system_prompt_file = "data/system_prompt.txt"

# --- Multi-NPC Orchestrator Mode ---
# When [[npcs]] is present, legacy single-NPC fields above are ignored.
# Each NPC gets its own WebSocket connection and LLM session.

[[npcs]]
account = "npc_guard"
password = ""
character_name = "Karl"                           # Auto-creates character if account has none
character_class = "knight"                              # Class for auto-creation (default: knight)
llm = "openrouter"

# 3-tier prompt system (overrides backend system_prompt_file when set):
template_prompt = "data/templates/guard.txt"             # Role-specific behavior rules (shared)
instance_prompt = "data/npcs/karl/instance.txt"         # Individual NPC personality
memory_file = "data/npcs/karl/memory.txt"               # Accumulated experiences (auto-updated)

# Per-NPC timing overrides (optional, defaults shown above)
# min_interval_secs = 5
# debounce_secs = 2
# idle_interval_secs = 3600
# activity_window_secs = 30

[[npcs]]
account = "npc_merchant"
password = ""
character_name = "Rica"
character_class = "merchant"
llm = "openrouter"
template_prompt = "data/templates/merchant.txt"
instance_prompt = "data/npcs/rica/instance.txt"
memory_file = "data/npcs/rica/memory.txt"
# schedule_file = "data/npcs/rica/schedule.json"          # Daily schedule (time-based positioning)
